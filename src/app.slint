// src/app.slint

export struct TimelineObject {
    id: int,
    start_frame: int,
    end_frame: int,
}

export component MainWindow inherits Window {
    preferred-width: 800px;
    preferred-height: 650px;
    title: "NeoUtl";

    in-out property <image> video-frame;
    in-out property <int> current-frame: 0;
    in-out property <int> total-frames: 300;
    in-out property <[TimelineObject]> objects: [];

    // ── Rust 側で実装するコールバック ──
    callback add-object-at(float, int);          // (ratio, kind_idx)
    callback delete-object(int);                 // (id)
    callback seek-timeline(float);               // (ratio)
    callback move-object(int, float);            // (id, new_start_ratio)
    callback request-render();
    // オブジェクトのヒット判定。ratio を渡すと重なるオブジェクトの id を返す（なければ -1）
    callback find-object-at(float) -> int;
    // オブジェクトの start_frame ratio を返す
    callback get-object-start-ratio(int) -> float;

    // コンテキストメニュー
    property <bool> show-context-menu: false;
    property <bool> menu-is-delete: false;   // true=削除メニュー, false=追加メニュー
    property <int>  menu-target-id: -1;      // 削除対象 id
    property <length> menu-x: 0px;
    property <length> menu-y: 0px;
    property <float>  click-ratio: 0.0;

    // ドラッグ状態: 0=idle, 1=seeking, 2=dragging-object
    property <int>    drag-mode: 0;
    property <int>    dragging-obj-id: -1;
    property <length> drag-mouse-start: 0px;
    property <float>  drag-obj-start-ratio: 0.0;  // ドラッグ開始時のオブジェクト先頭 ratio

    Timer {
        interval: 16ms;
        running: true;
        triggered() => { root.request-render(); }
    }

    FocusScope {
        key-pressed(event) => { accept }
        TouchArea {
            pointer-event(e) => {
                if (e.button == PointerEventButton.left && e.kind == PointerEventKind.down) {
                    root.show-context-menu = false;
                }
            }
        }
    }

    VerticalLayout {
        padding: 15px;
        spacing: 10px;

        Rectangle {
            background: #121214;
            height: 400px;
            Image {
                source: root.video-frame;
                width: 100%;
                height: 100%;
            }
        }

        Text {
            text: "Timeline  —  左ドラッグ: シーク  |  オブジェクト左ドラッグ: 移動  |  右クリック: メニュー";
            color: #aaaaaa;
            font-size: 11px;
        }

        // ━━━ タイムライン本体 ━━━
        timeline-rect := Rectangle {
            background: #1e1e22;
            border-radius: 4px;
            height: 80px;

            // カーソルライン
            Rectangle {
                background: #ff4500;
                width: 2px;
                height: parent.height;
                x: (root.current-frame / root.total-frames) * parent.width;
            }

            // オブジェクト矩形（描画のみ・イベントなし）
            for obj in root.objects : Rectangle {
                property <bool> is-drag: root.drag-mode == 2 && root.dragging-obj-id == obj.id;
                background: is-drag ? #5a7fef : #3a5fcd;
                border-width: 1px;
                border-color: is-drag ? #aaccff : #63b8ff;
                border-radius: 2px;
                y: 10px;
                height: 60px;
                x: (obj.start-frame / root.total-frames) * parent.width;
                width: ((obj.end-frame - obj.start-frame) / root.total-frames) * parent.width;
                Text {
                    text: "ID:" + obj.id;
                    color: white;
                    font-size: 11px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            // ── タイムライン全体 TouchArea（唯一のイベント処理） ──
            timeline-touch := TouchArea {
                mouse-cursor: root.drag-mode == 2 ? MouseCursor.grabbing
                            : root.drag-mode == 1 ? MouseCursor.col-resize
                            : MouseCursor.default;

                pointer-event(e) => {
                    if (e.kind == PointerEventKind.down) {
                        root.show-context-menu = false;
                        let press-ratio = self.pressed-x / self.width;

                        if (e.button == PointerEventButton.right) {
                            // ヒット判定して削除 or 追加メニューを選択
                            let hit-id = root.find-object-at(press-ratio);
                            root.click-ratio = press-ratio;
                            root.menu-target-id = hit-id;
                            root.menu-is-delete = hit-id >= 0;
                            root.menu-x = timeline-rect.absolute-position.x + self.pressed-x;
                            root.menu-y = timeline-rect.absolute-position.y + self.pressed-y + 4px;
                            root.show-context-menu = true;

                        } else if (e.button == PointerEventButton.left) {
                            root.drag-mouse-start = self.pressed-x;
                            let hit-id = root.find-object-at(press-ratio);
                            if (hit-id >= 0) {
                                // オブジェクトドラッグ開始
                                root.drag-mode = 2;
                                root.dragging-obj-id = hit-id;
                                root.drag-obj-start-ratio = root.get-object-start-ratio(hit-id);
                            } else {
                                // シーク開始
                                root.drag-mode = 1;
                                root.seek-timeline(press-ratio);
                            }
                        }
                    }

                    if (e.kind == PointerEventKind.up || e.kind == PointerEventKind.cancel) {
                        root.drag-mode = 0;
                        root.dragging-obj-id = -1;
                    }
                }

                moved() => {
                    if (root.drag-mode == 1) {
                        // シーク
                        root.seek-timeline((self.mouse-x / self.width).clamp(0.0, 1.0));
                    } else if (root.drag-mode == 2) {
                        // オブジェクト移動:
                        // ドラッグ開始時のオブジェクト先頭 ratio + マウス移動量 ratio
                        let delta-ratio = (self.mouse-x - root.drag-mouse-start) / self.width;
                        let new-ratio = (root.drag-obj-start-ratio + delta-ratio).clamp(0.0, 1.0);
                        root.move-object(root.dragging-obj-id, new-ratio);
                    }
                }
            }
        }

        Text {
            text: "Frame: " + root.current-frame + " / " + root.total-frames;
            horizontal-alignment: center;
            color: #cccccc;
        }
    }

    // ━━━ コンテキストメニュー ━━━
    if (root.show-context-menu) : Rectangle {
        x: root.menu-x;
        y: root.menu-y;
        width: 160px;
        // 削除メニュー: 1項目(34px) + padding, 追加メニュー: 2項目
        height: root.menu-is-delete ? 38px : 68px;
        background: #2d2d30;
        border-width: 1px;
        border-color: #555558;
        border-radius: 4px;
        drop-shadow-blur: 8px;
        drop-shadow-color: #00000066;
        drop-shadow-offset-x: 2px;
        drop-shadow-offset-y: 2px;

        // 削除メニュー（オブジェクト上で右クリックしたとき）
        if (root.menu-is-delete) : VerticalLayout {
            padding: 2px;
            Rectangle {
                background: del-touch.has-hover ? #5a1a1a : transparent;
                height: 30px;
                border-radius: 3px;
                Text { text: "  🗑 Delete Object"; color: #ff8888; font-size: 12px; vertical-alignment: center; }
                del-touch := TouchArea {
                    clicked() => {
                        root.delete-object(root.menu-target-id);
                        root.show-context-menu = false;
                    }
                }
            }
        }

        // 追加メニュー（空白で右クリックしたとき）
        if (!root.menu-is-delete) : VerticalLayout {
            padding: 2px;
            spacing: 0px;
            Rectangle {
                background: item1-touch.has-hover ? #3e3e42 : transparent;
                height: 30px;
                border-radius: 3px;
                Text { text: "  ＋ Add Tetrahedron"; color: white; font-size: 12px; vertical-alignment: center; }
                item1-touch := TouchArea {
                    clicked() => { root.add-object-at(root.click-ratio, 0); root.show-context-menu = false; }
                }
            }
            Rectangle {
                background: item2-touch.has-hover ? #3e3e42 : transparent;
                height: 30px;
                border-radius: 3px;
                Text { text: "  ＋ Add Cube"; color: white; font-size: 12px; vertical-alignment: center; }
                item2-touch := TouchArea {
                    clicked() => { root.add-object-at(root.click-ratio, 1); root.show-context-menu = false; }
                }
            }
        }
    }
}
