{
    "id": "audio",
    "name": "音声",
    "category": "object",
    "qml": "AudioObject.qml",
    "params": {
        "source": "",
        "startOffset": 0,
        "speed": 100.0,
        "volume": 1.0,
        "pan": 0.0,
        "mute": false
    },
    "ui": {
        "group": "object",
        "controls": [
            { "param": "source", "label": "ファイルパス", "type": "file", "filter": "Audio Files (*.wav *.mp3 *.aac *.m4a)" },
            { "param": "startOffset", "label": "開始位置(秒)", "type": "float", "min": 0, "max": 3600 },
            { "param": "speed", "label": "再生速度(%)", "type": "float", "min": 1, "max": 400, "default": 100 },
            { "param": "volume", "label": "音量", "type": "slider", "min": 0, "max": 2, "step": 0.01 },
            { "param": "pan", "label": "パン", "type": "slider", "min": -1, "max": 1, "step": 0.1 },
            { "param": "mute", "label": "ミュート", "type": "bool" }
        ]
    }
}