{
    "id": "GroupControl",
    "name": "グループ制御",
    "category": "object",
    "qml": "GroupControlObject.qml",
    "params": {
        "layerCount": 1,
        "x": 0,
        "y": 0,
        "z": 0,
        "scale": 100,
        "rotationX": 0,
        "rotationY": 0,
        "rotationZ": 0,
        "opacity": 1.0
    },
    "ui": {
        "group": "object",
        "controls": [
            { "type": "int", "param": "layerCount", "label": "対象レイヤー数", "min": 1, "max": 100 },
            { "type": "float", "param": "x", "label": "X", "min": -4000, "max": 4000 },
            { "type": "float", "param": "y", "label": "Y", "min": -4000, "max": 4000 },
            { "type": "float", "param": "z", "label": "Z", "min": -4000, "max": 4000 },
            { "type": "float", "param": "scale", "label": "拡大率", "min": 0, "max": 5000 },
            { "type": "float", "param": "rotationX", "label": "回転X", "min": -3600, "max": 3600 },
            { "type": "float", "param": "rotationY", "label": "回転Y", "min": -3600, "max": 3600 },
            { "type": "float", "param": "rotationZ", "label": "回転Z", "min": -3600, "max": 3600 },
            { "type": "slider", "param": "opacity", "label": "不透明度", "min": 0, "max": 1, "step": 0.01 }
        ]
    }
}