{
    "id": "image",
    "name": "画像",
    "category": "object",
    "qml": "ImageObject.qml",
    "params": {
        "path": "",
        "smooth": true,
        "opacity": 1.0
    },
    "ui": {
        "group": "object",
        "controls": [
            {
                "type": "path",
                "param": "path",
                "label": "ファイルパス",
                "filter": "画像ファイル (*.png *.jpg *.jpeg *.bmp *.svg)"
            },
            {
                "type": "bool",
                "param": "smooth",
                "label": "スムーズ描画"
            },
            {
                "type": "slider",
                "param": "opacity",
                "label": "不透明度",
                "min": 0,
                "max": 1,
                "step": 0.01
            }
        ]
    }
}