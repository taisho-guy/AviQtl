{
    "id": "scene",
    "name": "シーンオブジェクト",
    "category": "object",
    "qml": "SceneObject.qml",
    "params": {
        "sceneId": 0,
        "speed": 1.0,
        "offset": 0,
        "opacity": 1.0
    },
    "ui": {
        "group": "object",
        "controls": [
            {
                "type": "combo",
