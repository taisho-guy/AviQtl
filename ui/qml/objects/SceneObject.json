                "max": 4.0,
                "step": 0.1
            },
            {
                "type": "spinner",
                "param": "offset",
                "label": "オフセット",
                "min": 0,
                "max": 100000
            },
            {
                "type": "slider",
                "param": "opacity",
                "label": "不透明度",
                "min": 0.0,
                "max": 1.0,
                "step": 0.01
            }
