{
    "id": "video",
    "name": "動画",
    "category": "object",
    "qml": "VideoObject.qml",
    "params": {
        "path": "",
        "opacity": 1.0,
        "startOffset": 0,
        "useFrameEasing": false,
        "speed": 100.0,
        "mute": false,
        "volume": 1.0
    },
    "ui": {
        "group": "object",
        "controls": [
            {
                "param": "path",
                "label": "ファイルパス",
                "type": "path",
                "filter": "Video files (*.mp4 *.avi *.mkv *.mov *.webm);;All files (*)"
            },
            {
                "param": "opacity",
                "label": "不透明度",
                "type": "slider",
                "min": 0.0,
                "max": 1.0,
                "step": 0.01
            },
            {
                "param": "startOffset",
                "label": "開始フレーム",
                "type": "int",
                "min": -99999,
                "max": 99999
            },
            {
                "param": "useFrameEasing",
                "label": "フレーム数で制御",
                "type": "bool"
            },
            {
                "param": "speed",
                "label": "再生速度(%) / 位置(%)",
                "type": "float",
                "min": -1000,
                "max": 1000,
                "default": 100
            },
            {
                "param": "mute",
                "label": "ミュート",
                "type": "bool"
            },
            {
                "param": "volume",
                "label": "音量",
                "type": "slider",
                "min": 0.0,
                "max": 2.0,
                "step": 0.1
            }
        ]
    }
}
