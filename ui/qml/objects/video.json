{
    "id": "video",
    "name": "動画",
    "qml": "VideoObject.qml",
    "params": {
        "path": "",
        "opacity": 1.0,
        "playMode": "開始フレーム＋再生速度",
        "startFrame": 0,
        "speed": 100.0,
        "directFrame": 0
    },
    "ui": {
        "controls": [
            {
                "type": "path",
                "param": "path",
                "label": "ファイル",
                "filter": "Video Files (*.mp4 *.mov *.avi *.mkv *.webm *.wmv)"
            },
            {
                "type": "float",
                "param": "opacity",
                "label": "不透明度",
                "min": 0.0,
                "max": 1.0,
                "decimals": 2
            },
            {
                "type": "enum",
                "param": "playMode",
                "label": "再生モード",
                "options": [
                    "開始フレーム＋再生速度",
                    "フレーム直接指定"
                ]
            },
            {
                "type": "header",
                "label": "開始フレーム＋再生速度"
            },
            {
                "type": "int",
                "param": "startFrame",
                "label": "開始フレーム",
                "min": 0,
                "unit": "f"
            },
            {
                "type": "float",
                "param": "speed",
                "label": "再生速度",
                "min": 0.1,
                "max": 1000.0,
                "decimals": 1,
                "unit": "%"
            },
            {
                "type": "header",
                "label": "フレーム直接指定"
            },
            {
                "type": "float",
                "param": "directFrame",
                "label": "フレーム番号",
                "min": 0
            }
        ]
    },
    "version": "1.0.0",
    "kind": "object",
    "categories": [
        "その他"
    ]
}