{
    "id": "video",
    "name": "動画",
    "category": "object",
    "qml": "VideoObject.qml",
    "params": {
        "path": "",
        "opacity": 1.0,
        "startOffset": 0,
        "mute": false,
        "volume": 1.0,
        "scale": 100
    },
    "ui": {
        "group": "object",
        "controls": [
            {
                "param": "path",
                "label": "ファイルパス",
                "type": "path",
                "filter": "Video files (*.mp4 *.avi *.mkv *.mov *.webm);;All files (*)"
            },
            {
                "param": "opacity",
                "label": "不透明度",
                "type": "slider",
                "min": 0.0,
                "max": 1.0,
                "step": 0.01
            },
            {
                "param": "startOffset",
                "label": "開始位置(ms)",
                "type": "slider",
                "min": 0,
                "max": 3600000,
                "step": 100
            },
            {
                "param": "mute",
                "label": "ミュート",
                "type": "bool"
            },
            {
                "param": "volume",
                "label": "音量",
                "type": "slider",
                "min": 0.0,
                "max": 2.0,
                "step": 0.1
            },
            {
                "param": "scale",
                "label": "拡大率(%)",
                "type": "slider",
                "min": 0,
                "max": 2000,
                "step": 1
            }
        ]
    }
}
