{
    "id": "camera_control",
    "name": "カメラ制御",
    "category": "object",
    "qml": "CameraControlObject.qml",
    "params": {
        "x":    0,
        "y":    0,
        "z":    0,
        "tx":   0,
        "ty":   0,
        "tz":   0,
        "roll": 0,
        "fov":  30
    },
    "ui": {
        "controls": [
            { "type": "float", "param": "x",    "default": 0,  "min": -9999, "max": 9999, "label": "X" },
            { "type": "float", "param": "y",    "default": 0,  "min": -9999, "max": 9999, "label": "Y" },
            { "type": "float", "param": "z",    "default": 0,  "min": -9999, "max": 9999, "label": "Z" },
            { "type": "float", "param": "tx",   "default": 0,  "min": -9999, "max": 9999, "label": "注視X" },
            { "type": "float", "param": "ty",   "default": 0,  "min": -9999, "max": 9999, "label": "注視Y" },
            { "type": "float", "param": "tz",   "default": 0,  "min": -9999, "max": 9999, "label": "注視Z" },
            { "type": "float", "param": "roll", "default": 0,  "min": -180,  "max": 180,  "label": "ロール" },
            { "type": "float", "param": "fov",  "default": 30, "min": 1,     "max": 170,  "label": "視野角" }
        ]
    }
}