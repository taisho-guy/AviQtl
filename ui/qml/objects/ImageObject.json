{
    "id": "image",
    "name": "画像",
    "category": "object",
    "qml": "ImageObject.qml",
    "params": {
        "path": "",
        "fillMode": 1,
        "smooth": true,
        "opacity": 1.0
    },
    "ui": {
        "path": {
            "type": "file",
            "label": "ファイルパス",
            "filter": "画像ファイル (*.png *.jpg *.jpeg *.bmp *.svg)"
        },
        "fillMode": {
            "type": "enum",
            "label": "リサイズモード",
            "values": {
                "0": "Stretch",
                "1": "PreserveAspectFit",
                "2": "PreserveAspectCrop",
                "4": "Pad"
            }
        },
        "smooth": { "type": "bool", "label": "スムーズ描画" },
        "opacity": { "type": "slider", "label": "不透明度", "min": 0, "max": 1, "step": 0.01 }
    }
}