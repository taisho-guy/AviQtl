{
    "id": "image_loop",
    "name": "画像ループ",
    "qml": "ImageLoop.qml",
    "params": {
        "countX": 2,
        "countY": 2,
        "intervalX": 0,
        "intervalY": 0,
        "mirror": false
    },
    "ui": {
        "controls": [
            {
                "type": "int",
                "param": "countX",
                "label": "横回数",
                "min": 1,
                "max": 100
            },
            {
                "type": "int",
                "param": "countY",
                "label": "縦回数",
                "min": 1,
                "max": 100
            },
            {
                "type": "float",
                "param": "intervalX",
                "label": "横間隔",
                "min": -1000,
                "max": 1000
            },
            {
                "type": "float",
                "param": "intervalY",
                "label": "縦間隔",
                "min": -1000,
                "max": 1000
            },
            {
                "type": "bool",
                "param": "mirror",
                "label": "反転配置"
            }
        ]
    },
    "version": "1.0.0",
    "kind": "effect",
    "categories": [
        "基本エフェクト"
    ]
