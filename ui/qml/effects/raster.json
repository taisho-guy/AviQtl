{
  "id": "raster",
  "name": "ラスター",
  "category": "filter",
  "qml": "Raster.qml",
  "color": "#44aadd",
  "params": {
    "amplitude": 50,
    "frequency": 50,
    "period": 1,
    "time": 0,
    "vertical": false,
    "randomAmplitude": 0
  },
  "ui": {
    "params": [
      {
        "type": "slider",
        "param": "amplitude",
        "label": "横幅",
        "min": 0,
        "max": 500,
        "default": 50
      },
      {
        "type": "slider",
        "param": "frequency",
        "label": "高さ",
        "min": 0,
        "max": 500,
        "default": 50
      },
      {
        "type": "slider",
        "param": "period",
        "label": "周期",
        "min": 0,
        "max": 10,
        "default": 1,
        "decimals": 1
      },
      {
        "type": "slider",
        "param": "time",
        "label": "時間(s)",
        "min": 0,
        "max": 3600,
        "default": 0,
        "decimals": 2
      },
      {
        "type": "bool",
        "param": "vertical",
        "label": "縦ラスター",
        "default": false
      },
      {
        "type": "slider",
        "param": "randomAmplitude",
        "label": "ランダム振幅",
        "min": 0,
        "max": 100,
        "default": 0
