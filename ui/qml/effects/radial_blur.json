{
    "id": "radial_blur",
    "name": "放射ブラー",
    "category": "filter",
    "qml": "RadialBlur.qml",
    "params": {
        "samples": 10,
        "strength": 0.1,
        "x": 0,
        "y": 0
    },
    "ui": {
        "controls": [
            { "type": "int", "param": "samples", "label": "サンプル数", "min": 1, "max": 32 },
            { "type": "float", "param": "strength", "label": "強さ", "min": 0, "max": 1, "step": 0.01 },
            { "type": "float", "param": "x", "label": "中心X", "min": -2000, "max": 2000 },
            { "type": "float", "param": "y", "label": "中心Y", "min": -2000, "max": 2000 }
        ]
    }
}