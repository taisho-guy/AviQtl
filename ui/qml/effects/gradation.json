{
  "id": "gradation",
  "name": "グラデーション",
  "category": "filter",
  "qml": "Gradation.qml",
  "color": "#884488",
  "params": {
    "strength": 100,
    "centerX": 0,
    "centerY": 0,
    "angle": 0,
    "gradWidth": 50,
    "shape": "line",
    "startColor": "#000000",
    "endColor": "#ffffff"
  },
  "ui": {
    "params": [
      {
        "type": "slider",
        "param": "strength",
        "label": "強さ",
        "min": 0,
        "max": 100,
        "default": 100,
        "decimals": 0
      },
      {
        "type": "slider",
        "param": "centerX",
        "label": "中心X",
        "min": -2000,
        "max": 2000,
        "default": 0,
        "decimals": 0
      },
      {
        "type": "slider",
        "param": "centerY",
        "label": "中心Y",
        "min": -2000,
        "max": 2000,
        "default": 0,
        "decimals": 0
      },
      {
        "type": "slider",
        "param": "angle",
        "label": "角度",
        "min": 0,
        "max": 360,
        "default": 0,
        "decimals": 0
      },
      {
        "type": "slider",
        "param": "gradWidth",
        "label": "幅",
        "min": 0,
        "max": 100,
        "default": 50,
        "decimals": 0
      },
      {
        "type": "enum",
        "param": "shape",
        "label": "形状",
        "options": [
          "line",
          "circle",
          "rect",
          "convex"
        ],
        "default": "line"
      },
      {
        "type": "color",
        "param": "startColor",
        "label": "開始色",
        "default": "#000000"
      },
      {
        "type": "color",
        "param": "endColor",
        "label": "終了色",
        "default": "#ffffff"
      }
    ]
  }
}