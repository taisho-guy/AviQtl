{
  "id": "pixelsorter",
  "name": "Pixel Sorter",
  "qml": "PixelSorter.qml",
  "params": {
    "blockSize": 24,
    "minLuma": 0.15,
    "maxLuma": 0.90,
    "direction": 0,
    "reverse": false,
    "mix": 1.0
  },
  "ui": {
    "controls": [
      {
        "type": "float",
        "param": "blockSize",
        "label": "Block Size",
        "min": 2,
        "max": 64,
        "step": 1
      },
      {
        "type": "slider",
        "param": "minLuma",
        "label": "Min Luma",
        "min": 0.0,
        "max": 1.0,
        "step": 0.01
      },
      {
        "type": "slider",
        "param": "maxLuma",
        "label": "Max Luma",
        "min": 0.0,
        "max": 1.0,
        "step": 0.01
      },
      {
        "type": "enum",
        "param": "direction",
        "label": "Direction",
        "options": ["Horizontal", "Vertical"]
      },
      {
        "type": "bool",
        "param": "reverse",
        "label": "Reverse"
      },
      {
        "type": "slider",
        "param": "mix",
        "label": "Mix",
        "min": 0.0,
        "max": 1.0,
        "step": 0.01
      }
    ]
  },
  "version": "1.0.0",
  "kind": "effect",
  "categories": ["Stylize", "Glitch"]
}
